# Server
PORT=3000
NODE_ENV=development

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-secret-key-min-16-chars

# CORS — set to your frontend origin (e.g. http://localhost:3000 or your Railway URL)
ALLOWED_ORIGIN=http://localhost:3000

# Database (local development — not needed if DATABASE_URL is set)
DB_USER=your_pg_username
DB_HOST=localhost
DB_NAME=iou_app
DB_PASSWORD=
DB_PORT=5432

# Database (production — Railway sets this automatically)
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Sentry (optional — Phase 2)
# SENTRY_DSN=https://...
